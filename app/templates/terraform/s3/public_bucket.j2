{#
  Remediates S3_PUBLIC_BUCKET finding
  Required variables: bucket_name
  Optional variables: region, account_id (for provider if needed)
  This template creates a public access block to prevent public access to the S3 bucket.
#}
resource "aws_s3_bucket_public_access_block" "remediate_{{ bucket_name }}" {
  bucket = aws_s3_bucket.{{ bucket_name }}.id
  block_public_acls   = true
  block_public_policy = true
  ignore_public_acls  = true
  restrict_public_buckets = true
}